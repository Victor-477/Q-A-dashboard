# TEACHER_PASSWORDS: passwords allowed to access the teacher page.
# Use one password or multiple comma-separated passwords.
TEACHER_PASSWORDS="professor123"

# PORT: initial server port. If it is busy, the system tries the next ports.
PORT=3000

# HOST: use 0.0.0.0 to accept access from other devices on the network.
HOST="0.0.0.0"

# APP_URL: URL where the application is hosted.
APP_URL="MY_APP_URL"
