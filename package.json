{
  "name": "q-and-a-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs server.ts",
    "dev:web": "node ./node_modules/tsx/dist/cli.mjs server.ts",
    "dashboard": "electron .",
    "desktop": "electron .",
    "build": "node ./node_modules/vite/bin/vite.js build && node ./node_modules/esbuild/bin/esbuild server.ts --bundle --platform=node --format=cjs --external:vite --sourcemap --outfile=dist/server.cjs",
    "dist:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run build && electron-builder --win portable",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start": "node dist/server.cjs",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('server.js', { force: true });\"",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "firewall:allow": "powershell -ExecutionPolicy Bypass -File scripts/allow-firewall.ps1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "local.qa-dashboard",
    "productName": "Q&A Dashboard",
    "artifactName": "QADashboard-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "icon": "assets/icon.ico",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "!node_modules"
    ],
    "asar": true,
    "asarUnpack": [
      "dist/**/*"
    ],
    "forceCodeSigning": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
